# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://commentguard:commentguard_dev@localhost:5432/commentguard

# ── JWT (CHECKLIST §10: secret must be ≥32 random bytes) ─────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Cloudflare R2 (S3-compatible, egress-free) ───────────────────
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=REPLACE_WITH_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=commentguard-evidence
R2_ENDPOINT_URL=https://REPLACE_WITH_R2_ACCOUNT_ID.r2.cloudflarestorage.com

# ── YouTube Data API v3 (CHECKLIST §8: never commit real keys) ────
YOUTUBE_API_KEY=REPLACE_WITH_YOUTUBE_API_KEY
YOUTUBE_QUOTA_LIMIT=9000

# ── OpenAI (CHECKLIST §10: no secrets in source code) ────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ── Google OAuth (NextAuth.js) ────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
NEXTAUTH_SECRET=REPLACE_WITH_NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000

# ── Internal service URLs ─────────────────────────────────────────
CLASSIFIER_URL=http://localhost:8001

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
