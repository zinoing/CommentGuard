generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  YOUTUBE
  INSTAGRAM
}

enum CaseStatus {
  OPEN
  UNDER_REVIEW
  PACKAGED
  REFERRED
  CLOSED
}

// CHECKLIST §3: only REQUEST_LEGAL_REVIEW is a valid CommentGuard action type.
// OPEN_ON_PLATFORM is a UI-only redirect with no DB write — not an enum value.
enum ActionType {
  REQUEST_LEGAL_REVIEW
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum UserRole {
  SUPER_ADMIN
  CHANNEL_MANAGER
  VIEWER
  LAW_FIRM
}

enum RiskType {
  LEGAL_THREAT
  HATE_SPEECH
  HARASSMENT
  SPAM
  COORDINATED_ATTACK
}

enum CollectJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model Tenant {
  id         String    @id @default(cuid())
  name       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  users      User[]
  channels   Channel[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  role         UserRole
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  approvedActions Action[] @relation("ApprovedBy")
  custodyLogs  CustodyLog[]
  createdCases Case[]
}

model Channel {
  id                  String    @id @default(cuid())
  platform            Platform
  platformChannelId   String
  name                String
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  apiCredentialsRef   String
  mcnId               String?
  oauthAccessToken    String?
  oauthRefreshToken   String?
  lastCollectedAt     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  comments            Comment[]

  @@unique([platform, platformChannelId])
}

// Immutable record: no updatedAt, no UPDATE routes allowed
model Comment {
  id                  String          @id @default(cuid())
  channelId           String
  channel             Channel         @relation(fields: [channelId], references: [id])
  platformCommentId   String
  text                String
  authorPlatformId    String
  snapshotR2Key       String?         // null until Phase 3 snapshot capture
  snapshotHash        String?         // null until Phase 3 snapshot capture
  snapshotHashAlg     String          @default("sha256")
  createdAt           DateTime        @default(now())
  riskAssessments     RiskAssessment[]
  actions             Action[]

  @@unique([channelId, platformCommentId])
}

// Immutable record: no updatedAt, classification always "reference_only"
model RiskAssessment {
  id                  String      @id @default(cuid())
  commentId           String
  comment             Comment     @relation(fields: [commentId], references: [id])
  riskTypes           RiskType[]
  legalScore          Float
  brandScore          Float
  urgencyScore        Float
  recommendedAction   ActionType?
  modelVersion        String
  classification      String      @default("reference_only")
  isProvisional       Boolean     @default(false)
  createdAt           DateTime    @default(now())
}

// Action requires human approval: approved_by is required before execution
model Action {
  id                  String        @id @default(cuid())
  commentId           String
  comment             Comment       @relation(fields: [commentId], references: [id])
  actionType          ActionType
  status              ActionStatus  @default(PENDING)
  approvedById        String?
  approvedBy          User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt          DateTime?
  executedAt          DateTime?
  platformResponse    Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Case {
  id               String          @id @default(cuid())
  title            String
  status           CaseStatus      @default(OPEN)
  createdById      String
  createdBy        User            @relation(fields: [createdById], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  custodyLogs      CustodyLog[]
  evidencePackages EvidencePackage[]
  shareLinks       ShareLink[]
}

// Append-only: no updatedAt, no UPDATE/DELETE queries on this table ever
model CustodyLog {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id])
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  ipAddress  String
  metadata   Json?
  createdAt  DateTime @default(now())
}

// Immutable record: case_id required (no orphaned packages)
model EvidencePackage {
  id                   String   @id @default(cuid())
  caseId               String
  case                 Case     @relation(fields: [caseId], references: [id])
  pdfR2Key             String
  custodyLogR2Key      String   // R2 key for immutable custody log file (CHECKLIST §1)
  timelinePageIncluded Boolean  @default(false)
  checksum             String   // SHA-256 of the PDF
  checksumAlg          String   @default("sha256")
  createdById          String
  createdAt            DateTime @default(now())
}

// Share link for law firms: crypto token, always expires
model ShareLink {
  id          String            @id @default(cuid())
  caseId      String
  case        Case              @relation(fields: [caseId], references: [id])
  token       String            @unique
  expiresAt   DateTime
  isRevoked   Boolean           @default(false)
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())
  accessLogs  ShareLinkAccess[]
}

// Log every access to share links
model ShareLinkAccess {
  id          String    @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id])
  ipAddress   String
  userAgent   String
  accessedAt  DateTime  @default(now())
  wasValid    Boolean
}

// MVP entity: account anomaly detection signals
// ip_cluster_id is an anonymized cluster token — never a raw IP
model AccountPattern {
  authorPlatformId String    @id
  commentCount30d  Int       @default(0)
  isNewAccount     Boolean   @default(false)
  ipClusterId      String?   // Anonymized cluster token, no raw IP stored
  flaggedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum ChannelInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model ChannelInvite {
  id          String              @id @default(cuid())
  mcnId       String
  channelName String
  token       String              @unique
  status      ChannelInviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime            @default(now())
}

model CollectJob {
  id               String           @id @default(cuid())
  channelId        String
  status           CollectJobStatus @default(PENDING)
  totalVideos      Int              @default(0)
  processedVideos  Int              @default(0)
  totalComments    Int              @default(0)
  newComments      Int              @default(0)
  modifiedComments Int              @default(0)
  deletedComments  Int              @default(0)
  errorMessage     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Ops Lane signal: spam/noise/bot observations — reference_only, never a judgment
model CommentOpsSignal {
  id              String   @id @default(cuid())
  commentId       String
  ruleVersion     String
  detectedAt      DateTime @default(now())
  spamFlags       String[]
  repetitionCount Int      @default(0)
  urlRatio        Float    @default(0)
  opsScore        Float
  labels          String[]
  classification  String   @default("reference_only")

  @@index([commentId])
}

// Legal Lane signal: element decomposition + embedding/NLI scores — reference_only
model CommentLegalSignal {
  id                  String   @id @default(cuid())
  commentId           String
  ruleVersion         String
  modelVersion        String   @default("rule-only-v2")
  detectedAt          DateTime @default(now())
  expressionType      String   // "fact" | "suspicion" | "opinion" | "quotation" | "mixed"
  targetSpecificity   String   // "explicit" | "implicit" | "none"
  allegationTypes     String[]
  assertionStrength   Int      // 0 | 1 | 2
  evidencePresent     Boolean
  evidenceTypes       String[]
  extractedEntities   String[]
  // per-detection-path signals (explainability)
  elementScore        Float    @default(0) // defamation element decomposition score
  embeddingScore      Float    @default(0) // best centroid/pattern similarity
  embeddingCategory   String?
  nliScore            Float    @default(0) // best NLI zero-shot probability
  nliHypothesis       String?
  legalScore          Float
  notes               String?
  requiresHumanReview Boolean  @default(false)
  classification      String   @default("reference_only")

  @@index([commentId])
  @@index([requiresHumanReview])
}

// Atomic observation labels (facts, not judgments)
model CommentLabel {
  id          String   @id @default(cuid())
  commentId   String
  label       String
  lane        String   // "legal" | "ops"
  source      String   // "rule" | "embedding" | "nli" | "element"
  ruleVersion String?
  detectedAt  DateTime @default(now())

  @@index([commentId])
  @@index([label])
}

// k-anonymity: NO channel_id, author_id, mcn_id, or any PII
// Only written when derived from >= 50 distinct channels
model NetworkPattern {
  id                   String   @id @default(cuid())
  patternType          String
  occurrenceCount      Int
  distinctChannelCount Int
  timeWindowStart      DateTime
  timeWindowEnd        DateTime
  metadata             Json?
  createdAt            DateTime @default(now())
}
