# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://commentguard:commentguard_dev@localhost:5432/commentguard

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── JWT (CHECKLIST §10: secret must be ≥32 random bytes) ─────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── AWS (use LocalStack endpoint for local dev) ───────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566   # Remove this line in production
S3_EVIDENCE_BUCKET=commentguard-evidence-dev
KMS_KEY_ID=REPLACE_WITH_KMS_KEY_ARN

# ── YouTube Data API v3 (CHECKLIST §8: never commit real keys) ────
YOUTUBE_API_KEY=REPLACE_WITH_YOUTUBE_API_KEY
YOUTUBE_QUOTA_LIMIT=9000

# ── OpenAI (CHECKLIST §10: no secrets in source code) ────────────
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# ── Service ports ─────────────────────────────────────────────────
PORT=3001                 # bff-api
# PORT=3002               # collector-service
# PORT=3003               # evidence-service
# PORT=3004               # action-service
# PORT=3005               # case-management
# PORT=3006               # network-intelligence

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
